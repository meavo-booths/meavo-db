{
  "name": "@meavo/db",
  "version": "0.32.0",
  "private": true,
  "description": "Canonical Prisma schema for the shared MEAVO Postgres database. The only repo allowed to alter the database.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meavo-booths/meavo-db.git"
  },
  "files": [
    "prisma",
    "scripts"
  ],
  "scripts": {
    "validate": "prisma validate",
    "diff": "prisma migrate diff --from-schema-datasource prisma/schema.prisma --to-schema-datamodel prisma/schema.prisma --script",
    "db:push": "prisma db push",
    "studio": "prisma studio"
  },
  "devDependencies": {
    "prisma": "^6.1.0"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  }
}
