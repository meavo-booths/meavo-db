// ============================================================================
// @meavo/db - canonical Prisma schema for the shared MEAVO Postgres database.
//
// This is the ONLY schema allowed to alter the database. App repos (gateway,
// hols, assembly, sales) consume this package and run `prisma generate` only.
// Schema changes: edit here, apply from this repo, tag a release, then bump
// the dependency in each app.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- Identity & access (owner: gateway) ----

enum SystemRole {
  ADMIN
  USER
}

enum TeamRole {
  MANAGER
  MEMBER
}

enum ToolCardKind {
  LINK
  APP_ACCESS
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  systemRole         SystemRole @default(USER)
  hrAccess           Boolean    @default(false)
  holidayCountryCode String?
  slackUserId        String?
  createdAt          DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts           Account[]
  teamMembers        TeamMember[]
  cardAccess         ToolCardAccess[]
  employee           Employee?
  vacationRequests   VacationRequest[] @relation("Requester")
  reviewedRequests   VacationRequest[] @relation("Reviewer")
  allowances         UserAllowance[]
  documentTemplatesCreated     DocumentTemplate[]        @relation("DocumentTemplateCreator")
  documentTemplateVersionsCreated DocumentTemplateVersion[] @relation("DocumentTemplateVersionCreator")
  generatedDocuments           GeneratedDocument[]       @relation("GeneratedDocumentCreator")
  generatedDocumentsAsSubject  GeneratedDocument[]       @relation("GeneratedDocumentSubject")
  libraryAssetsUploaded      LibraryAsset[]
  salaryHistoryChanged       EmployeeSalaryHistory[]     @relation("SalaryHistoryChanger")

  mrpProfile                 MrpUserProfile?
  mrpDocumentsCreated        MrpDocument[]        @relation("MrpDocumentCreator")
  mrpDocumentsApproved       MrpDocument[]        @relation("MrpDocumentApprover")
  mrpCorrectionLogs          MrpCorrectionLog[]   @relation("MrpCorrectionAuthor")
  mrpRecipeExceptionsCreated MrpRecipeException[] @relation("MrpRecipeExceptionCreator")
  mrpStockMovementsCreated   MrpStockMovement[]   @relation("MrpStockMovementCreator")
  mrpProductionBatchesCreated MrpProductionBatch[] @relation("MrpProductionBatchCreator")
  mrpInventoryCountsCreated  MrpInventoryCount[]  @relation("MrpInventoryCountCreator")

  taskWorkspacesOwned   TaskWorkspace[]       @relation("TaskWorkspaceOwner")
  taskWorkspaceMembers  TaskWorkspaceMember[]
  tasksCreated          Task[]                @relation("TaskCreator")
  taskAssignments       TaskAssignee[]

  notifications           Notification[]
  notificationPreferences UserNotificationPreference[]
  appAnnouncements        AppAnnouncement[]            @relation("AppAnnouncementAuthor")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Team {
  id              String       @id @default(cuid())
  name            String       @unique
  color           String       @default("#EEDCDC")
  yearlyAllowance Int          @default(25)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  members         TeamMember[]
  taskWorkspaces  TaskWorkspace[]
}

model TeamMember {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  role      TeamRole @default(MEMBER)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
}

model ToolCard {
  id           String           @id @default(cuid())
  name         String
  description  String
  url          String
  iconKey      String?
  kind         ToolCardKind     @default(LINK)
  linkedAppKey String?
  sortOrder    Int              @default(0)
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  access       ToolCardAccess[]

  @@unique([linkedAppKey])
}

model ToolCardAccess {
  id        String   @id @default(cuid())
  userId    String
  cardId    String
  createdAt DateTime @default(now())

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  card ToolCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
}

model LoginThrottle {
  key         String   @id
  attempts    Int      @default(0)
  windowStart DateTime @default(now())
}

// ---- HR & documents (owner: gateway) ----

enum Company {
  MEAVO
  OA
}

model CompanyProfile {
  company       Company  @id
  legalName     String   @default("")
  legalNameBg   String   @default("")
  address       String   @default("")
  addressBg     String   @default("")
  companyNumber String   @default("")
  vatNumber     String   @default("")
  deVatNumber   String   @default("")
  eori          String   @default("")
  manager       String   @default("")
  managerBg     String   @default("")
  extraTaxFtePercent        Decimal @default(0) @db.Decimal(5, 2)
  extraTaxFreelancerPercent Decimal @default(0) @db.Decimal(5, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum ContractType {
  FTE
  FREELANCE
}

model Employee {
  id                     String       @id @default(cuid())
  userId                 String       @unique
  company                Company
  contract               ContractType
  startDate              DateTime     @db.Date
  endDate                DateTime?    @db.Date
  role                   String
  employeeBirthdate      DateTime?    @db.Date
  employeePersonalEmail  String       @default("")
  employeeHomeAddress    String       @default("")
  employeeHomeAddressBg  String       @default("")
  providerCompanyName    String       @default("")
  providerCompanyNameBg  String       @default("")
  providerCompanyAddress String       @default("")
  providerCompanyAddressBg String     @default("")
  providerCompanyRegNumber String     @default("")
  providerCompanyVatNumber String     @default("")
  yearlySalary             Decimal?   @db.Decimal(12, 2)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents     EmployeeDocument[]
  salaryHistory EmployeeSalaryHistory[]
}

model EmployeeSalaryHistory {
  id            String   @id @default(cuid())
  employeeId    String
  yearlySalary  Decimal  @db.Decimal(12, 2)
  effectiveFrom DateTime @db.Date
  changedById   String
  note          String   @default("")
  createdAt     DateTime @default(now())

  employee  Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  changedBy User     @relation("SalaryHistoryChanger", fields: [changedById], references: [id], onDelete: Restrict)

  @@index([employeeId, effectiveFrom])
}

model EmployeeDocument {
  id         String   @id @default(cuid())
  employeeId String
  fileName   String
  mimeType   String
  storageKey String
  uploadedBy String
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model DocumentTemplate {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String

  createdBy User                      @relation("DocumentTemplateCreator", fields: [createdById], references: [id], onDelete: Restrict)
  versions  DocumentTemplateVersion[]
}

model DocumentTemplateVersion {
  id                 String   @id @default(cuid())
  templateId         String
  versionNumber      Int
  body               String   @db.Text
  customPlaceholders String   @default("[]")
  isCurrent          Boolean  @default(true)
  createdAt          DateTime @default(now())
  createdById        String

  template             DocumentTemplate    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  createdBy            User                @relation("DocumentTemplateVersionCreator", fields: [createdById], references: [id], onDelete: Restrict)
  generatedDocuments   GeneratedDocument[]

  @@unique([templateId, versionNumber])
  @@index([templateId, isCurrent])
}

model GeneratedDocument {
  id                String   @id @default(cuid())
  templateVersionId String
  generatedById     String
  subjectUserId     String?
  company           Company?
  filledValues      String   @db.Text
  warnings          String   @default("[]")
  fileName          String
  storageKey        String
  createdAt         DateTime @default(now())

  templateVersion DocumentTemplateVersion @relation(fields: [templateVersionId], references: [id], onDelete: Restrict)
  generatedBy     User                    @relation("GeneratedDocumentCreator", fields: [generatedById], references: [id], onDelete: Restrict)
  subjectUser     User?                   @relation("GeneratedDocumentSubject", fields: [subjectUserId], references: [id], onDelete: SetNull)

  @@index([templateVersionId])
  @@index([subjectUserId])
}

model LibraryAsset {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  fileName     String?
  mimeType     String?
  storageKey   String?
  uploadedById String?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  uploadedBy User? @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
}

model GatewaySheetRecord {
  id             String    @id @default(cuid())
  rowKey         String    @unique
  data           Json
  invoiceDate    DateTime?
  revenueEur     Decimal?  @db.Decimal(12, 2)
  salesRep       String?
  market         String?
  clientType     String?
  newVsRepeat    String?
  lastImportedAt DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([lastImportedAt])
  @@index([invoiceDate])
  @@index([market])
  @@index([clientType])
  @@index([newVsRepeat])
}

// ---- Vacation tracking (owner: hols) ----

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model PublicHoliday {
  id          String   @id @default(cuid())
  countryCode String
  date        DateTime @db.Date
  localName   String   @default("")
  name        String   @default("")
  year        Int
  createdAt   DateTime @default(now())

  @@unique([countryCode, date])
  @@index([countryCode, year])
}

model UserAllowance {
  id        String   @id @default(cuid())
  userId    String
  year      Int
  days      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year])
}

model VacationRequest {
  id           String        @id @default(cuid())
  userId       String
  startDate    DateTime
  endDate      DateTime
  days         Float
  note         String?
  status       RequestStatus @default(PENDING)
  reviewedById String?
  reviewedAt   DateTime?
  reviewNote   String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user       User  @relation("Requester", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("Reviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([startDate, endDate])
}

// ---- Assembly (owner: assembly) ----

enum SubmissionStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
}

enum QuestionnaireLocale {
  EN
  DE
  FR
  ES
  IT
  CS
  NL
}

enum TranslationStatus {
  DRAFT
  APPROVED
  STALE
}

enum QuestionType {
  CHECKBOX
  TEXT
  YES_NO
}

enum AssemblySource {
  SHEET_IMPORTED
  APP_CREATED
}

enum AssemblyEventType {
  ASSEMBLY
  REPAIR
  MOVING_SERVICE
  AFTERCARE
  INFO
}

enum AssemblyInternalTeam {
  NO
  LAT
}

enum AssemblyIssue {
  PENDING
  YES
  NO
}

model AssemblyPartner {
  id         String   @id @default(cuid())
  name       String   @unique
  slug       String   @unique
  email      String?
  codeHash   String?
  isActive   Boolean  @default(true)
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  assemblies  Assembly[]
  submissions QuestionnaireSubmission[]
}

model Assembly {
  id                  String    @id @default(cuid())
  /// Unique assembly identifier (sheet column B, URL param). Historically the
  /// business DealID; for app-created assemblies it is a renameable name
  /// auto-suggested as "{DEALID}-ASS".
  dealId              String    @unique

  /// Business DealID of the sales deal this assembly belongs to. Several
  /// assemblies (assembly, repair, aftercare, ...) can link to one deal.
  linkedDealId String?
  assemblyDate        DateTime? @db.Date
  market              String    @default("")
  clientName          String    @default("")
  channelType         String    @default("")
  deliveryPartnerName String    @default("")
  installPartnerName  String    @default("")
  installPartnerId    String?
  lastImportedAt      DateTime  @default(now())
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // App-only (not written to the sheet)
  source          AssemblySource       @default(SHEET_IMPORTED)
  eventType       AssemblyEventType    @default(ASSEMBLY)
  internalTeam    AssemblyInternalTeam @default(NO)
  clientEmail     String?
  clientPhone     String?
  assemblyAddress String?
  assemblyTime    String? // HH:mm in Europe/London; app-only, not written to sheet
  sheetRowNumber  Int?
  sheetSyncError  String?

  // Sheet-mirrored (columns F/G/H/K/L/M/O)
  closure       Boolean       @default(false)
  survey        Boolean       @default(false)
  fulfilledOn   DateTime?     @db.Date
  issue           AssemblyIssue @default(PENDING)
  status          String?
  priority        String?
  comments        String?
  issueCategories String[]

  installPartner AssemblyPartner?          @relation(fields: [installPartnerId], references: [id], onDelete: SetNull)
  linkedDeal     Deal?                     @relation(fields: [linkedDealId], references: [dealId], onDelete: SetNull)
  submissions    QuestionnaireSubmission[]

  @@index([installPartnerId])
  @@index([assemblyDate])
  @@index([linkedDealId])
  @@index([market, assemblyDate])
}

model Questionnaire {
  id          String   @id @default(cuid())
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sections  QuestionnaireSection[]
  questions Question[]
}

model QuestionnaireSection {
  id              String   @id @default(cuid())
  questionnaireId String
  title           String
  sortOrder       Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  questionnaire Questionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  questions     Question[]
  translations  QuestionnaireSectionTranslation[]

  @@index([questionnaireId, sortOrder])
}

model Question {
  id                      String       @id @default(cuid())
  questionnaireId         String
  sectionId               String?
  parentQuestionId        String?
  text                    String
  type                    QuestionType @default(CHECKBOX)
  sortOrder               Int
  required                Boolean      @default(true)
  endsQuestionnaireOnNo   Boolean      @default(false)
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  questionnaire     Questionnaire         @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  section             QuestionnaireSection? @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  parentQuestion      Question?             @relation("QuestionFollowUp", fields: [parentQuestionId], references: [id], onDelete: Cascade)
  followUpQuestions   Question[]            @relation("QuestionFollowUp")
  answers             QuestionAnswer[]
  translations        QuestionTranslation[]

  @@index([questionnaireId, sortOrder])
  @@index([sectionId, sortOrder])
}

model QuestionnaireSectionTranslation {
  sectionId String
  locale    QuestionnaireLocale
  title     String
  status    TranslationStatus @default(DRAFT)
  updatedAt DateTime          @updatedAt

  section QuestionnaireSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@id([sectionId, locale])
}

model QuestionTranslation {
  questionId String
  locale     QuestionnaireLocale
  text       String
  status     TranslationStatus @default(DRAFT)
  updatedAt  DateTime            @updatedAt

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@id([questionId, locale])
}

model QuestionnaireSubmission {
  id          String           @id @default(cuid())
  assemblyId  String
  partnerId   String
  status      SubmissionStatus @default(NOT_STARTED)
  submittedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  assembly Assembly          @relation(fields: [assemblyId], references: [id], onDelete: Cascade)
  partner  AssemblyPartner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  answers  QuestionAnswer[]
  photos   SubmissionPhoto[]

  @@unique([assemblyId, partnerId])
  @@index([partnerId])
}

model QuestionAnswer {
  id           String   @id @default(cuid())
  submissionId String
  questionId   String
  checked      Boolean  @default(false)
  textAnswer   String   @default("")
  yesNoAnswer  Boolean?

  submission QuestionnaireSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question   Question                @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, questionId])
}

model SubmissionPhoto {
  id           String   @id @default(cuid())
  submissionId String
  storageKey   String
  fileName     String
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  submission QuestionnaireSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
}

model SheetImportState {
  id           String    @id @default("default")
  lastRunAt    DateTime?
  rowCount     Int       @default(0)
  errorMessage String?
}

enum BoothModel {
  SOHO
  WORKSTATION
  CAMDEN_2
  CAMDEN_4
  HAVEN_ONE
  HAVEN_FOCUS
  HAVEN_2
  HAVEN_4
}

enum ResourceType {
  PDF
  YOUTUBE
  LINK
  IMAGE
}

enum ResourceCategoryKind {
  DELIVERY
  ASSEMBLY
  ELECTRICAL
  REPAIRS
}

model Resource {
  id             String       @id @default(cuid())
  title          String
  description    String       @default("")
  type           ResourceType
  youtubeUrl     String?
  youtubeVideoId String?
  linkUrl        String?
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  models     ResourceBoothModel[]
  categories ResourceCategory[]
  files      ResourceFile[]

  @@index([sortOrder])
}

model ResourceFile {
  id         String   @id @default(cuid())
  resourceId String
  storageKey String
  fileName   String
  mimeType   String
  caption    String   @default("")
  createdAt  DateTime @default(now())

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId])
}

model ResourceBoothModel {
  resourceId String
  boothModel BoothModel

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@id([resourceId, boothModel])
}

model ResourceCategory {
  resourceId String
  category   ResourceCategoryKind

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@id([resourceId, category])
}

// ---- Sales (owner: sales) ----

enum DealStage {
  QUOTE
  WON
  LOST
}

enum PaymentTerms {
  UPFRONT_100
  SPLIT_50_50
  NET_30
}

enum DealClientType {
  DIRECT
  AGENCY
  COWORKING
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}

enum DealContactKind {
  MAIN
  FINANCE
  ASSEMBLY
}

enum DeliveryType {
  DI
  DELIVERY_ONLY
  KERBSIDE
  FACTORY_PICKUP
}

enum ProductFinish {
  CUSTOM
  WHITE_STOCK
  BLACK_STOCK
  LDF_COLOUR
}

enum BoothUnitStatus {
  PLANNED
  IN_PRODUCTION
  IN_STORAGE
  IN_TRANSIT
  ASSEMBLED
  OTHER
}

enum ProductKind {
  BOOTH
  ADDON
}

enum BoothProductFamily {
  SOHO
  WORKSTATION
  CAMDEN_2
  CAMDEN_4
  HAVEN_ONE
  HAVEN_FOCUS
  HAVEN_2
  HAVEN_4
}

enum AddOnProductFamily {
  BAR_STOOL
  OFFICE_CHAIR
  MONITOR
  MONITOR_WITH_CAMERA
  WARRANTY
  ASSEMBLY
  MOVING_SERVICE
}

model Product {
  id          String      @id @default(cuid())
  name        String
  version     String      @default("")
  kind        ProductKind @default(BOOTH)
  boothFamily BoothProductFamily?
  addOnFamily AddOnProductFamily?
  description String      @default("")
  imageUrl    String?
  listPrice   Decimal     @default(0) @db.Decimal(12, 2)
  /// Catalog list price currency (EUR, GBP, CZK, or USD).
  currency    String      @default("EUR")
  isActive    Boolean     @default(true)
  /// Zamp product tax code for US sales tax (Sales-owned; never overwritten by Xero sync).
  taxCode     String      @default("")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Xero item link (owner: sales) — set by the Xero items import. Commercial
  // fields (name, description, listPrice, isActive) are overwritten on sync
  // for linked products; kind, images and restrictions stay Sales-owned.
  xeroItemId   String?   @unique
  xeroItemCode String?
  xeroSyncedAt DateTime?

  lineItems  QuoteLineItem[]
  boothUnits BoothUnit[]

  /// For ADDON products: booth families this add-on is limited to. No rows = any family.
  familyRestrictions ProductAddOnFamilyRestriction[]

  /// Markets and client types this product is sold for. No rows = all combinations.
  availability ProductAvailability[]

  @@index([isActive])
  @@index([kind])
  @@index([version])
  @@index([boothFamily])
  @@index([addOnFamily])
}

model ProductAvailability {
  productId  String
  market     String
  clientType DealClientType

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([productId, market, clientType])
  @@index([market, clientType])
}

model ProductAddOnFamilyRestriction {
  addOnId     String
  boothFamily BoothProductFamily

  addOn Product @relation(fields: [addOnId], references: [id], onDelete: Cascade)

  @@id([addOnId, boothFamily])
  @@index([boothFamily])
}

model Client {
  id                String         @id @default(cuid())
  name              String
  registeredAddress String         @default("")
  vatNumber         String         @default("")
  clientType        DealClientType @default(DIRECT)
  market            String         @default("")
  website           String         @default("")
  isVip             Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  /// Xero contact link (owner: sales) — cached after find-or-create so
  /// invoices for repeat clients reuse the same Xero contact.
  xeroContactId String?

  /// Parent company (e.g. "Amazon"). Null = standalone client or group head.
  parentClientId String?

  parent       Client?  @relation("ClientHierarchy", fields: [parentClientId], references: [id], onDelete: SetNull)
  subsidiaries Client[] @relation("ClientHierarchy")

  contacts ClientContact[]
  deals    Deal[]

  @@index([name])
  @@index([parentClientId])
}

model ClientContact {
  id        String          @id @default(cuid())
  clientId  String
  kind      DealContactKind @default(MAIN)
  name      String
  email     String          @default("")
  phone     String          @default("")
  role      String          @default("")
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model Deal {
  id          String    @id @default(cuid())
  quoteNumber String    @unique
  stage       DealStage @default(QUOTE)

  /// Business DealID (invoice/PO convention) — entered by the rep when the
  /// quote is won. Same key as Assembly.dealId and GatewaySheetRecord.rowKey.
  dealId String? @unique

  /// Client directory link. The client fields below stay as a snapshot taken
  /// at quote time, so editing a client never rewrites past quotes.
  clientId String?

  dealDate          DateTime       @db.Date
  salesRep          String         @default("")
  market            String         @default("")
  /// US state for deals in the US market (2-letter code, e.g. "CA").
  usState           String         @default("")
  /// Structured US ship-to address for Zamp sales tax (US market only).
  shipToLine1       String         @default("")
  shipToLine2       String         @default("")
  shipToCity        String         @default("")
  shipToZip         String         @default("")
  clientName        String
  registeredAddress String         @default("")
  /// Client website URL snapshot at quote time.
  website           String         @default("")
  vatNumber         String         @default("")
  /// Customer purchase order reference.
  clientPo          String         @default("")
  /// End customer when the billed client is an agency or intermediary.
  actualClient      String         @default("")
  clientType        DealClientType @default(DIRECT)
  paymentTerms      PaymentTerms   @default(UPFRONT_100)
  paymentStatus     PaymentStatus  @default(UNPAID)
  paymentPoDate     DateTime?      @db.Date
  currency          String         @default("EUR")
  /// 1 unit of `currency` equals this many EUR (e.g. 1 GBP = 1.17 EUR).
  exchangeRateToEur Decimal?       @db.Decimal(18, 8)
  notes             String         @default("")

  /// Where the booths get installed — distinct from registeredAddress (invoicing).
  assemblyAddress String @default("")

  /// Electrical socket fitting for the booth(s), e.g. UK, EU, US.
  socketType String @default("")

  /// Customer target delivery date agreed on the quote.
  targetDeliveryDate DateTime? @db.Date

  /// How the booth is delivered to the customer site.
  deliveryType DeliveryType?

  /// Set by sales once the deal is invoiced/paid and can be scheduled for
  /// assembly. Surfaces the deal on the assembly app's Ready deals page.
  readyToAssemble Boolean @default(false)

  wonAt           DateTime?
  createdByUserId String?

  // Ops File write-back bookkeeping
  sheetRows      Json?
  sheetSyncedAt  DateTime?
  sheetSyncError String?

  // Xero invoice bookkeeping (owner: sales) — set when the won deal is
  // exported to Xero as a draft ACCREC invoice.
  xeroInvoiceId     String?   @unique
  xeroInvoiceNumber String?
  xeroSyncedAt      DateTime?
  xeroSyncError     String?

  // US sales tax (Zamp) — computed on quote save for US market; committed on win.
  usTaxAmount       Decimal        @default(0) @db.Decimal(12, 2)
  usTaxDetail       Json?
  zampTransactionId String?        @unique
  zampSyncedAt      DateTime?
  zampSyncError     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client     Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  contacts   DealContact[]
  lineItems  QuoteLineItem[]
  boothUnits BoothUnit[]
  assemblies Assembly[]

  @@index([stage])
  @@index([dealDate])
  @@index([clientName])
  @@index([clientId])
  @@index([readyToAssemble])
}

model DealContact {
  id        String          @id @default(cuid())
  dealId    String
  kind      DealContactKind @default(MAIN)
  name      String
  email     String          @default("")
  phone     String          @default("")
  role      String          @default("")
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
}

model QuoteLineItem {
  id            String        @id @default(cuid())
  dealId        String
  /// Null on custom one-off lines, which carry their name in customName.
  productId     String?
  quantity      Int           @default(1)
  unitPrice     Decimal       @db.Decimal(12, 2)
  /// EUR equivalent of unitPrice at save time (for reporting). Null on legacy rows.
  unitPriceEur  Decimal?      @db.Decimal(12, 2)
  finish        ProductFinish @default(WHITE_STOCK)
  finishDetails String        @default("")
  description   String        @default("")
  sortOrder     Int           @default(0)

  /// Free-text item name for custom one-off lines (productId is null).
  customName String @default("")

  /// Set on add-on lines that are attached to a booth line (extra warranty,
  /// chair, ...). Attached add-ons render under their booth on the PDF and
  /// join the booth's row in the Ops File.
  parentLineItemId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deal    Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: Restrict)

  parent QuoteLineItem?  @relation("LineItemAddOns", fields: [parentLineItemId], references: [id], onDelete: SetNull)
  addOns QuoteLineItem[] @relation("LineItemAddOns")

  @@index([dealId])
  @@index([productId])
  @@index([parentLineItemId])
}

model BoothUnit {
  id            String          @id @default(cuid())
  /// Business DealID — references Deal.dealId (not Deal.id) so the future
  /// manufacturing and logistics tools can query by the cross-app key.
  dealId        String
  productId     String
  finish        ProductFinish   @default(WHITE_STOCK)
  finishDetails String          @default("")
  location      String          @default("")
  status        BoothUnitStatus @default(PLANNED)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  deal    Deal    @relation(fields: [dealId], references: [dealId], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([dealId])
  @@index([status])
  @@index([productId])
}

// ---- Xero integration (owner: sales) ----

/// Admin-confirmed mapping from a Sales market to the Xero Branding Theme
/// (invoice template) used for that market's invoices. Theme name is cached
/// for display; the ID is what the Xero API needs.
model XeroMarketThemeMapping {
  market            String   @id
  brandingThemeId   String
  brandingThemeName String
  updatedAt         DateTime @updatedAt
}

/// Admin-confirmed mapping from a Sales market to the Xero TaxType applied
/// to invoice line items (e.g. UK -> OUTPUT2 for 20% VAT).
model XeroMarketTaxMapping {
  market    String   @id
  taxType   String
  taxName   String   @default("")
  /// Effective rate cached from Xero for display, e.g. 20.000.
  taxRate   Decimal? @db.Decimal(6, 3)
  updatedAt DateTime @updatedAt
}

/// Admin-confirmed mapping from a Sales market to the Xero revenue account
/// invoice lines post to (e.g. UK -> 200 "Sales UK").
model XeroMarketAccountMapping {
  market      String   @id
  accountCode String
  accountName String   @default("")
  updatedAt   DateTime @updatedAt
}

/// Reference mapping from a Sales market to the expected Xero VAT/tax liability
/// account. Not used in invoice export today — VAT posts via Tax Type.
model XeroMarketTaxAccountMapping {
  market          String   @id
  taxAccountCode  String
  taxAccountName  String   @default("")
  updatedAt       DateTime @updatedAt
}

/// Per-US-state Xero mapping for won deals in the US market (theme, revenue
/// account, exempt tax type, and sales-tax liability account).
model XeroUsStateMapping {
  state               String   @id
  brandingThemeId     String   @default("")
  brandingThemeName   String   @default("")
  accountCode         String   @default("")
  accountName         String   @default("")
  taxType             String   @default("")
  taxName             String   @default("")
  taxRate             Decimal? @db.Decimal(6, 3)
  taxAccountCode      String   @default("")
  taxAccountName      String   @default("")
  updatedAt           DateTime @updatedAt
}

/// Singleton row (id = "xero") with integration-wide state. Auto-invoicing
/// on deal win stays disabled until setupConfirmedAt is set by an admin.
model XeroIntegrationSettings {
  id                       String    @id @default("xero")
  setupConfirmedAt         DateTime?
  usSetupConfirmedAt       DateTime?
  defaultBrandingThemeId   String?
  defaultBrandingThemeName String?
  defaultTaxType           String?
  defaultAccountCode       String?
  defaultAccountName       String?
  defaultTaxAccountCode    String?
  defaultTaxAccountName    String?
  defaultUsBrandingThemeId   String?
  defaultUsBrandingThemeName String?
  defaultUsAccountCode       String?
  defaultUsAccountName       String?
  defaultUsTaxType           String?
  defaultUsTaxAccountCode    String?
  defaultUsTaxAccountName    String?
  lastXeroItemsSyncAt      DateTime?
  updatedAt                DateTime  @updatedAt
}

// ---- Notifications (owner: gateway) ----

enum NotificationStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

model NotificationOutbox {
  id             String             @id @default(cuid())
  sourceApp      String
  eventType      String
  idempotencyKey String?            @unique
  payload        Json
  status         NotificationStatus @default(PENDING)
  attempts       Int                @default(0)
  lastError      String?
  scheduledFor   DateTime           @default(now())
  sentAt         DateTime?
  createdAt      DateTime           @default(now())

  deliveries NotificationDelivery[]

  @@index([status, scheduledFor])
}

enum NotificationChannel {
  EMAIL
  IN_APP
  SLACK
}

model NotificationDelivery {
  id              String              @id @default(cuid())
  outboxId        String
  channel         NotificationChannel @default(EMAIL)
  recipientEmail  String
  recipientUserId String?
  subject         String
  resendMessageId String?
  status          NotificationStatus  @default(PENDING)
  sentAt          DateTime?
  error           String?
  createdAt       DateTime            @default(now())

  outbox NotificationOutbox @relation(fields: [outboxId], references: [id], onDelete: Cascade)

  @@index([outboxId])
  @@index([createdAt])
}

model NotificationEventSetting {
  eventType    String   @id
  enabled      Boolean  @default(true)
  emailEnabled Boolean  @default(true)
  inAppEnabled Boolean  @default(true)
  slackEnabled Boolean  @default(false)
  updatedAt    DateTime @updatedAt
}

// In-app bell notification items, written by gateway's outbox processor and
// read by every app's shared navigation bell.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  outboxId  String?
  sourceApp String
  eventType String
  title     String
  body      String
  url       String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

// Per-user channel opt-outs. Absence of a row means the channel is on
// (subject to the admin-level NotificationEventSetting toggles).
model UserNotificationPreference {
  id        String              @id @default(cuid())
  userId    String
  eventType String
  channel   NotificationChannel
  enabled   Boolean             @default(true)
  updatedAt DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventType, channel])
}

// Company-wide announcements shown on gateway's Library "App News" page.
// Body uses the gateway template-markup dialect (headings, bullets, **bold**).
model AppAnnouncement {
  id          String   @id @default(cuid())
  title       String
  body        String
  publishedAt DateTime @default(now())
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User? @relation("AppAnnouncementAuthor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([publishedAt])
}

// ---- Manufacturing / MRP (owner: mrp) ----

enum MrpRole {
  scanner
  reviewer
  admin
}

enum MrpDocumentType {
  invoice
  proforma
  delivery_note
}

enum MrpDocumentStatus {
  pending_review
  approved
  rejected
  synced
  sync_failed
}

enum MrpDeliveryZone {
  local
  eu
  non_eu
}

enum MrpSyncAdapter {
  stub
  export
  api
  agent
}

enum MrpSyncStatus {
  queued
  running
  succeeded
  failed
}

enum MrpStockMovementType {
  initial
  manual_receipt
  zeron_receipt
  production_out
  element_consumption
  batch_complete_flush
  inventory_count
  bom_rework_adjustment
}

enum MrpManufacturingBatchStatus {
  planned
  in_production
  completed
  cancelled
}

enum MrpRecipeExceptionStatus {
  active
  reverted
}

enum MrpRecipeExceptionChangeType {
  remove
  add
}

/// App-specific role for MRP; identity lives in gateway User.
model MrpUserProfile {
  userId    String   @id
  role      MrpRole  @default(scanner)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MrpSupplier {
  id              String           @id @default(cuid())
  name            String
  /// lowercased + trimmed for matching
  normalizedName  String
  vatNumber       String?
  /// Bulgarian company identifier
  eik             String?
  /// ISO-3166-1 alpha-2
  countryCode     String?
  address         String?
  /// ISO-4217 (e.g. BGN, EUR)
  defaultCurrency String?
  deliveryZone    MrpDeliveryZone?
  zeronId         String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  extractionProfile MrpSupplierExtractionProfile?
  documents         MrpDocument[]
  correctionLogs    MrpCorrectionLog[]

  @@index([normalizedName])
  @@index([vatNumber])
  @@index([eik])
}

/// Per-supplier extraction profile — drives few-shot learning.
model MrpSupplierExtractionProfile {
  supplierId     String   @id
  /// Free-form hints injected into the AI prompt.
  hints          Json     @default("{}")
  /// Recent approved extractions used as few-shot examples (capped at 5, FIFO).
  recentExamples Json     @default("[]")
  updatedAt      DateTime @updatedAt

  supplier MrpSupplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}

/// A scanned document (invoice / proforma / delivery note).
model MrpDocument {
  id             String            @id @default(cuid())
  type           MrpDocumentType
  documentNumber String?
  issueDate      DateTime?         @db.Date
  dueDate        DateTime?         @db.Date
  deliveryDate   DateTime?         @db.Date

  supplierId      String?
  /// Snapshot of supplier text on the document (in case supplierId is null/unmatched)
  supplierNameRaw String?

  currency String?
  subtotal Decimal? @db.Decimal(18, 4)
  vatTotal Decimal? @db.Decimal(18, 4)
  total    Decimal? @db.Decimal(18, 4)

  deliveryZone MrpDeliveryZone?
  /// MRN / МДД / МАД (only for non-EU)
  customsRef   String?

  status MrpDocumentStatus @default(pending_review)

  /// Vercel Blob pathname of the original file
  storageKey        String
  thumbnailKey      String?
  originalMimeType  String?
  originalSizeBytes BigInt?
  /// SHA-256 of the original bytes — used to dedupe re-uploads.
  contentHash       String?

  /// Raw extraction returned by the AI provider (untouched).
  rawAiExtraction Json?
  /// Confidence map: { "field.path": 0.0-1.0 }.
  confidence      Json  @default("{}")
  /// Final reviewed extraction (matches the zod schema after edits).
  finalExtraction Json?

  extractorProvider String?

  zeronId  String?
  syncedAt DateTime?

  createdById  String?
  approvedById String?
  approvedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  supplier     MrpSupplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  createdBy    User?              @relation("MrpDocumentCreator", fields: [createdById], references: [id], onDelete: SetNull)
  approvedBy   User?              @relation("MrpDocumentApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  lineItems    MrpLineItem[]
  corrections  MrpCorrectionLog[]
  syncAttempts MrpSyncAttempt[]

  @@index([supplierId])
  @@index([status])
  @@index([createdAt])
  @@index([contentHash])
  @@index([createdById, createdAt(sort: Desc)])
  @@index([createdById, contentHash])
}

/// Line items extracted from a document.
model MrpLineItem {
  id                 String   @id @default(cuid())
  documentId         String
  /// 1-based row index
  position           Int
  sku                String?
  name               String
  quantity           Decimal? @db.Decimal(18, 4)
  unit               String?
  unitPrice          Decimal? @db.Decimal(18, 4)
  vatRate            Decimal? @db.Decimal(6, 3)
  lineTotal          Decimal? @db.Decimal(18, 4)
  matchedZeronItemId String?
  notes              String?
  createdAt          DateTime @default(now())

  document MrpDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, position])
  @@index([documentId])
}

/// Every field-level edit a user makes vs the AI extraction — drives learning.
model MrpCorrectionLog {
  id            String   @id @default(cuid())
  documentId    String
  supplierId    String?
  /// dot+brackets path, e.g. "supplier.vatNumber" or "lineItems[2].unitPrice"
  fieldPath     String
  aiValue       Json?
  userValue     Json?
  note          String?
  correctedById String?
  correctedAt   DateTime @default(now())

  document    MrpDocument  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  supplier    MrpSupplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  correctedBy User?        @relation("MrpCorrectionAuthor", fields: [correctedById], references: [id], onDelete: SetNull)

  @@index([documentId])
  @@index([supplierId, fieldPath])
}

/// Audit log of every Zeron sync attempt.
model MrpSyncAttempt {
  id          String         @id @default(cuid())
  documentId  String
  adapter     MrpSyncAdapter
  status      MrpSyncStatus
  /// Payload we attempted to send (for replay/debugging).
  payload     Json?
  /// Response or output (XLSX path, API JSON, etc.).
  response    Json?
  error       String?
  attemptedAt DateTime       @default(now())
  completedAt DateTime?
  isCurrent   Boolean        @default(true)

  document MrpDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([status])
  @@index([documentId, isCurrent])
  @@index([attemptedAt(sort: Desc)])
}

/// Physical warehouse / site (Аксаково, Варна, Казанлък, …).
model MrpWarehouse {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  manufacturingBatches MrpManufacturingBatch[]
  stockMovements       MrpStockMovement[]
  stockBalances        MrpStockBalance[]
  inventoryCounts      MrpInventoryCount[]
}

/// Booth product line synced from Google Sheets (Soho, Camden 4, …).
model MrpBoothModel {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  elements             MrpBoothElement[]
  manufacturingBatches MrpManufacturingBatch[]
  exceptionScopes      MrpRecipeExceptionScope[]
}

/// Checklist column on batch Опаковане tab (Таван, Под, …) per model.
model MrpBoothElement {
  id           String   @id @default(cuid())
  boothModelId String
  sheetHeader  String
  /// Short label used in ElementBOM CSV (may differ from sheetHeader).
  simpleName   String
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  boothModel        MrpBoothModel                  @relation(fields: [boothModelId], references: [id], onDelete: Cascade)
  bomLines          MrpElementBomLine[]
  batchUnitElements MrpBatchUnitElement[]
  exceptionChanges  MrpRecipeExceptionLineChange[]

  @@unique([boothModelId, sheetHeader])
  @@unique([boothModelId, simpleName])
}

/// Raw materials tracked for stock (Zeron item code optional until API sync).
model MrpMaterial {
  id              String   @id @default(cuid())
  /// Zeron / internal SKU — unique when set.
  code            String?  @unique
  name            String
  unit            String   @default("kg")
  unitPriceEur    Decimal? @db.Decimal(18, 4)
  /// Denormalized default-warehouse on-hand; see MrpStockBalance per site.
  currentQuantity Decimal  @default(0) @db.Decimal(18, 4)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bomLines             MrpElementBomLine[]
  exceptionChanges     MrpRecipeExceptionLineChange[]
  stockMovements       MrpStockMovement[]
  stockBalances        MrpStockBalance[]
  productionBatchLines MrpProductionBatchLine[]
  inventoryCounts      MrpInventoryCount[]

  @@index([name])
  @@index([isActive])
  @@index([isActive, name])
}

/// Material code referenced in ElementBOM but not yet in materials master.
model MrpBomMissingMaterialCode {
  code         String   @id
  bomLineCount Int      @default(1)
  updatedAt    DateTime @updatedAt
}

/// Materials consumed to complete one element on one booth.
model MrpElementBomLine {
  id             String   @id @default(cuid())
  boothElementId String
  materialId     String
  /// Empty/null = all exterior colours (wildcard).
  colour         String?
  /// null = all markets; default = non-US; US = US booths only.
  market         String?
  quantity       Decimal  @db.Decimal(18, 4)
  createdAt      DateTime @default(now())

  boothElement MrpBoothElement @relation(fields: [boothElementId], references: [id], onDelete: Cascade)
  material     MrpMaterial     @relation(fields: [materialId], references: [id], onDelete: Restrict)

  @@unique([boothElementId, colour, market, materialId])
}

/// Row from master sheet Статус на партиди (synced from Google Sheets).
model MrpManufacturingBatch {
  id                 String                      @id @default(cuid())
  name               String
  status             MrpManufacturingBatchStatus @default(planned)
  boothModelId       String?
  qty                Int?
  warehouseId        String?
  masterSheetRowKey  String                      @unique
  batchSpreadsheetId String?
  /// Business DealID — aligns with Deal.dealId / BoothUnit.dealId for
  /// future sales → factory linkage.
  dealId             String?
  lastSyncedAt       DateTime?
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt

  boothModel     MrpBoothModel?                 @relation(fields: [boothModelId], references: [id], onDelete: SetNull)
  warehouse      MrpWarehouse?                  @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  units          MrpBatchUnit[]
  exceptionLinks MrpRecipeExceptionBatchLink[]

  @@index([status])
  @@index([name])
}

/// One booth row on batch Опаковане tab.
model MrpBatchUnit {
  id                   String   @id @default(cuid())
  manufacturingBatchId String
  sheetRowIndex        Int
  boothIdText          String?
  colour               String?
  progressPct          Decimal? @db.Decimal(6, 2)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  manufacturingBatch MrpManufacturingBatch @relation(fields: [manufacturingBatchId], references: [id], onDelete: Cascade)
  elements           MrpBatchUnitElement[]

  @@unique([manufacturingBatchId, sheetRowIndex])
}

/// Checkbox state per element on a batch unit row.
model MrpBatchUnitElement {
  id              String    @id @default(cuid())
  batchUnitId     String
  boothElementId  String
  isComplete      Boolean   @default(false)
  completedAt     DateTime?
  deductionPosted Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  batchUnit    MrpBatchUnit    @relation(fields: [batchUnitId], references: [id], onDelete: Cascade)
  boothElement MrpBoothElement @relation(fields: [boothElementId], references: [id], onDelete: Restrict)

  @@unique([batchUnitId, boothElementId])
}

/// Named temporary override to standard recipes (e.g. material substitution).
model MrpRecipeException {
  id          String                   @id @default(cuid())
  name        String
  notes       String?
  status      MrpRecipeExceptionStatus @default(active)
  createdById String?
  createdAt   DateTime                 @default(now())
  revertedAt  DateTime?

  createdBy   User?                          @relation("MrpRecipeExceptionCreator", fields: [createdById], references: [id], onDelete: SetNull)
  scopes      MrpRecipeExceptionScope[]
  lineChanges MrpRecipeExceptionLineChange[]
  batchLinks  MrpRecipeExceptionBatchLink[]

  @@index([status])
  @@index([status, createdAt(sort: Desc)])
}

/// Models / colour / market where an exception applies (null = wildcard).
model MrpRecipeExceptionScope {
  id           String  @id @default(cuid())
  exceptionId  String
  boothModelId String
  colour       String?
  market       String?

  exception  MrpRecipeException @relation(fields: [exceptionId], references: [id], onDelete: Cascade)
  boothModel MrpBoothModel      @relation(fields: [boothModelId], references: [id], onDelete: Cascade)

  @@unique([exceptionId, boothModelId, colour, market])
  @@index([exceptionId])
}

/// BOM line removals or additions for an exception.
model MrpRecipeExceptionLineChange {
  id             String                       @id @default(cuid())
  exceptionId    String
  boothElementId String
  changeType     MrpRecipeExceptionChangeType
  materialId     String
  quantity       Decimal                      @db.Decimal(18, 4)
  colour         String?
  market         String?

  exception    MrpRecipeException @relation(fields: [exceptionId], references: [id], onDelete: Cascade)
  boothElement MrpBoothElement    @relation(fields: [boothElementId], references: [id], onDelete: Cascade)
  material     MrpMaterial        @relation(fields: [materialId], references: [id], onDelete: Restrict)

  @@index([exceptionId])
}

/// Link exception to production batch (whole batch or specific booths).
model MrpRecipeExceptionBatchLink {
  id                   String  @id @default(cuid())
  exceptionId          String
  batchLabel           String
  manufacturingBatchId String?
  applyToWholeBatch    Boolean @default(true)
  boothIdTexts         Json    @default("[]")

  exception          MrpRecipeException     @relation(fields: [exceptionId], references: [id], onDelete: Cascade)
  manufacturingBatch MrpManufacturingBatch? @relation(fields: [manufacturingBatchId], references: [id], onDelete: SetNull)

  @@index([exceptionId])
}

/// Cron / manual Google Sheets sync audit.
model MrpSheetSyncLog {
  id           String    @id @default(cuid())
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  tabsRead     Int?
  rowsUpserted Int?
  errors       Json      @default("[]")
}

/// Immutable ledger of quantity changes.
model MrpStockMovement {
  id            String               @id @default(cuid())
  warehouseId   String
  materialId    String
  movementType  MrpStockMovementType
  /// Signed delta applied to on-hand quantity (positive = in, negative = out).
  quantityDelta Decimal              @db.Decimal(18, 4)
  effectiveAt   DateTime
  notes         String?
  /// MrpProductionBatch.id, future zeron event id, etc.
  referenceId   String?
  metadata      Json                 @default("{}")
  createdById   String?
  createdAt     DateTime             @default(now())

  warehouse       MrpWarehouse        @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  material        MrpMaterial         @relation(fields: [materialId], references: [id], onDelete: Cascade)
  createdBy       User?               @relation("MrpStockMovementCreator", fields: [createdById], references: [id], onDelete: SetNull)
  inventoryCounts MrpInventoryCount[]

  @@index([warehouseId])
  @@index([materialId])
  @@index([effectiveAt])
}

/// On-hand quantity per warehouse × material (cache; ledger is source of truth).
model MrpStockBalance {
  id          String   @id @default(cuid())
  warehouseId String
  materialId  String
  quantity    Decimal  @default(0) @db.Decimal(18, 4)
  updatedAt   DateTime @updatedAt

  warehouse MrpWarehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  material  MrpMaterial  @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, materialId])
}

/// Planned production run — drives forecast, does not change stock until recorded.
model MrpProductionBatch {
  id             String   @id @default(cuid())
  productionDate DateTime @db.Date
  label          String?
  notes          String?
  createdById    String?
  createdAt      DateTime @default(now())

  createdBy User?                    @relation("MrpProductionBatchCreator", fields: [createdById], references: [id], onDelete: SetNull)
  lines     MrpProductionBatchLine[]

  @@index([productionDate])
}

/// Material consumption per planned production batch.
model MrpProductionBatchLine {
  id         String   @id @default(cuid())
  batchId    String
  materialId String
  quantity   Decimal  @db.Decimal(18, 4)
  createdAt  DateTime @default(now())

  batch    MrpProductionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  material MrpMaterial        @relation(fields: [materialId], references: [id], onDelete: Restrict)

  @@unique([batchId, materialId])
  @@index([batchId])
  @@index([materialId])
}

/// Physical inventory count (инвентаризация) with variance audit.
model MrpInventoryCount {
  id                       String   @id @default(cuid())
  warehouseId              String
  materialId               String
  countDate                DateTime @db.Date
  systemQuantity           Decimal  @db.Decimal(18, 4)
  countedQuantity          Decimal  @db.Decimal(18, 4)
  /// counted − system at time of count
  variance                 Decimal  @db.Decimal(18, 4)
  notes                    String?
  /// Production checkpoint: physical count reflects stock through this batch (inclusive).
  countedThroughBatchId    String?
  /// Batch name when not linked yet, or denormalized for display.
  countedThroughBatchLabel String?
  movementId               String?
  createdById              String?
  createdAt                DateTime @default(now())

  warehouse MrpWarehouse      @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  material  MrpMaterial       @relation(fields: [materialId], references: [id], onDelete: Cascade)
  movement  MrpStockMovement? @relation(fields: [movementId], references: [id], onDelete: SetNull)
  createdBy User?             @relation("MrpInventoryCountCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([materialId])
  @@index([countDate])
}

// ---- Factory floor (owner: factory) ----

enum FactoryBatchStatus {
  planned
  active
  paused
  done
}

enum FactoryQuotaPeriod {
  day
  week
  month
}

enum FactoryPlanningBatchStatus {
  proposed
  planned
  active
  paused
  ready
  cancelled
}

enum FactoryPlanningBoothStatus {
  planned
  active
  ready
}

/// Station grouping (roles table in the old Factory Supabase schema).
model FactoryStationRole {
  id        String   @id @default(cuid())
  code      String   @unique
  nameBg    String?
  createdAt DateTime @default(now())

  stations FactoryStation[]
}

model FactoryStation {
  id          String   @id @default(cuid())
  code        String   @unique
  nameBg      String
  roleId      String?
  sortOrder   Int      @default(0)
  tracksColor Boolean  @default(true)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  role              FactoryStationRole?                @relation(fields: [roleId], references: [id])
  bomRequirements   FactoryStationElementRequirement[]
  workItems         FactoryStationWorkItem[]
  productionEvents  FactoryProductionEvent[]
  workSessions      FactoryWorkSession[]
  quotas            FactoryQuota[]
  devices           FactoryDevice[]
  cncMachines       FactoryCncMachineMap[]
  cncDailySummaries FactoryCncDailySummary[]
  taskOverrides     FactoryScheduleTaskOverride[]
}

model FactoryBoothModel {
  id        String   @id @default(cuid())
  code      String   @unique
  nameBg    String
  notes     String?
  createdAt DateTime @default(now())

  bomRequirements   FactoryStationElementRequirement[]
  productionBatches FactoryProductionBatch[]
  planningBatches   FactoryPlanningBatch[]
  planningBooths    FactoryPlanningBooth[]
}

/// Elements (parts).
model FactoryElement {
  id        String   @id @default(cuid())
  code      String   @unique
  nameBg    String
  createdAt DateTime @default(now())

  bomRequirements  FactoryStationElementRequirement[]
  dependents       FactoryStationElementRequirement[] @relation("FactoryElementDependency")
  workItems        FactoryStationWorkItem[]
  productionEvents FactoryProductionEvent[]
  workSessions     FactoryWorkSession[]
  quotas           FactoryQuota[]
  taskOverrides    FactoryScheduleTaskOverride[]
}

/// BOM: which station produces which element per booth model, incl. the
/// glue → cure → assembly process steps.
model FactoryStationElementRequirement {
  id                 String  @id @default(cuid())
  boothModelId       String
  stationId          String
  elementId          String
  qtyPerBooth        Int
  processNameBg      String?
  sequenceOrder      Int     @default(0)
  processStep        String  @default("single")
  dependsOnElementId String?
  minDelayMinutes    Int     @default(0)
  displayNameBg      String?

  boothModel       FactoryBoothModel @relation(fields: [boothModelId], references: [id], onDelete: Cascade)
  station          FactoryStation    @relation(fields: [stationId], references: [id], onDelete: Cascade)
  element          FactoryElement    @relation(fields: [elementId], references: [id], onDelete: Cascade)
  dependsOnElement FactoryElement?   @relation("FactoryElementDependency", fields: [dependsOnElementId], references: [id], onDelete: SetNull)

  @@unique([boothModelId, stationId, elementId, processStep])
}

model FactoryColor {
  id        String   @id @default(cuid())
  code      String   @unique
  nameBg    String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  batchColors      FactoryProductionBatchColor[]
  workItems        FactoryStationWorkItem[]
  productionEvents FactoryProductionEvent[]
  workSessions     FactoryWorkSession[]
}

/// Booth options (Privacy Foil, etc.)
model FactoryBoothOption {
  id        String   @id @default(cuid())
  code      String   @unique
  nameBg    String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  unitOptions FactoryProductionBoothUnitOption[]
}

model FactoryProductionBatch {
  id              String             @id @default(cuid())
  batchCode       String             @unique
  boothModelId    String
  priority        Int                @default(1)
  plannedStart    DateTime?          @db.Date
  plannedEnd      DateTime?          @db.Date
  status          FactoryBatchStatus @default(planned)
  scheduleVersion Int                @default(1)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  boothModel       FactoryBoothModel             @relation(fields: [boothModelId], references: [id])
  colors           FactoryProductionBatchColor[]
  workItems        FactoryStationWorkItem[]
  productionEvents FactoryProductionEvent[]
  workSessions     FactoryWorkSession[]
  quotas           FactoryQuota[]
  taskOverrides    FactoryScheduleTaskOverride[]

  @@index([status])
}

/// Batch × colour lines.
model FactoryProductionBatchColor {
  id             String @id @default(cuid())
  batchId        String
  colorId        String
  targetBoothQty Int
  usBooths       Int    @default(0)

  batch      FactoryProductionBatch       @relation(fields: [batchId], references: [id], onDelete: Cascade)
  color      FactoryColor                 @relation(fields: [colorId], references: [id])
  boothUnits FactoryProductionBoothUnit[]

  @@unique([batchId, colorId])
}

/// Individual booth units (auto-generated + overrides).
model FactoryProductionBoothUnit {
  id           String  @id @default(cuid())
  batchColorId String
  unitIndex    Int
  unitLabel    String
  isUs         Boolean @default(false)
  notes        String?
  status       String  @default("active")

  batchColor       FactoryProductionBatchColor        @relation(fields: [batchColorId], references: [id], onDelete: Cascade)
  options          FactoryProductionBoothUnitOption[]
  workItems        FactoryStationWorkItem[]
  productionEvents FactoryProductionEvent[]
  workSessions     FactoryWorkSession[]

  @@unique([batchColorId, unitIndex])
  @@unique([batchColorId, unitLabel])
}

model FactoryProductionBoothUnitOption {
  boothUnitId String
  optionId    String

  boothUnit FactoryProductionBoothUnit @relation(fields: [boothUnitId], references: [id], onDelete: Cascade)
  option    FactoryBoothOption         @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@id([boothUnitId, optionId])
}

/// Materialized work queue per station. Rebuilt wholesale by the
/// materializeWorkItems service (was a Postgres RPC on Supabase).
/// qtyRemaining (was a generated column) is computed in the app:
/// max(0, qtyRequired - qtyGood).
model FactoryStationWorkItem {
  id               String    @id @default(cuid())
  batchId          String
  stationId        String
  elementId        String
  colorId          String?
  boothUnitId      String?
  qtyRequired      Int       @default(0)
  qtyGood          Int       @default(0)
  qtyScrap         Int       @default(0)
  priority         Int       @default(1)
  dueDate          DateTime? @db.Date
  processStep      String    @default("single")
  displayNameBg    String?
  cureDelayMinutes Int       @default(0)
  updatedAt        DateTime  @updatedAt

  batch     FactoryProductionBatch      @relation(fields: [batchId], references: [id], onDelete: Cascade)
  station   FactoryStation              @relation(fields: [stationId], references: [id], onDelete: Cascade)
  element   FactoryElement              @relation(fields: [elementId], references: [id], onDelete: Cascade)
  color     FactoryColor?               @relation(fields: [colorId], references: [id])
  boothUnit FactoryProductionBoothUnit? @relation(fields: [boothUnitId], references: [id], onDelete: SetNull)

  @@unique([batchId, stationId, elementId, colorId, boothUnitId, processStep])
  @@index([stationId])
  @@index([batchId])
}

/// Production events from floor kiosks (idempotent on clientEventId).
model FactoryProductionEvent {
  id            String    @id @default(cuid())
  stationId     String
  batchId       String
  elementId     String
  colorId       String?
  boothUnitId   String?
  isUs          Boolean   @default(false)
  qtyGood       Int       @default(0)
  qtyScrap      Int       @default(0)
  processStep   String    @default("single")
  recordedAt    DateTime  @default(now())
  clientEventId String    @unique
  workSessionId String?
  syncedAt      DateTime?
  createdAt     DateTime  @default(now())

  station     FactoryStation              @relation(fields: [stationId], references: [id])
  batch       FactoryProductionBatch      @relation(fields: [batchId], references: [id])
  element     FactoryElement              @relation(fields: [elementId], references: [id])
  color       FactoryColor?               @relation(fields: [colorId], references: [id])
  boothUnit   FactoryProductionBoothUnit? @relation(fields: [boothUnitId], references: [id])
  workSession FactoryWorkSession?         @relation(fields: [workSessionId], references: [id])

  @@index([stationId, recordedAt(sort: Desc)])
  @@index([batchId])
}

model FactoryWorkSession {
  id          String    @id @default(cuid())
  stationId   String
  batchId     String
  elementId   String
  colorId     String?
  boothUnitId String?
  startedAt   DateTime  @default(now())
  endedAt     DateTime?

  station   FactoryStation              @relation(fields: [stationId], references: [id])
  batch     FactoryProductionBatch      @relation(fields: [batchId], references: [id])
  element   FactoryElement              @relation(fields: [elementId], references: [id])
  color     FactoryColor?               @relation(fields: [colorId], references: [id])
  boothUnit FactoryProductionBoothUnit? @relation(fields: [boothUnitId], references: [id])
  events    FactoryProductionEvent[]
}

model FactoryQuota {
  id        String             @id @default(cuid())
  period    FactoryQuotaPeriod
  targetQty Int
  stationId String?
  elementId String?
  batchId   String?
  validFrom DateTime?          @db.Date
  validTo   DateTime?          @db.Date
  createdAt DateTime           @default(now())

  station FactoryStation?         @relation(fields: [stationId], references: [id], onDelete: Cascade)
  element FactoryElement?         @relation(fields: [elementId], references: [id], onDelete: Cascade)
  batch   FactoryProductionBatch? @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

/// Manual station assignment and task order on the schedule board.
model FactoryScheduleTaskOverride {
  batchId           String
  elementId         String
  processStep       String   @default("single")
  assignedStationId String
  sortOrder         Int      @default(0)
  updatedAt         DateTime @updatedAt

  batch           FactoryProductionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  element         FactoryElement         @relation(fields: [elementId], references: [id], onDelete: Cascade)
  assignedStation FactoryStation         @relation(fields: [assignedStationId], references: [id], onDelete: Cascade)

  @@id([batchId, elementId, processStep])
  @@index([assignedStationId, sortOrder])
}

/// Kiosk devices (token-authenticated floor PCs).
model FactoryDevice {
  id          String    @id @default(cuid())
  stationId   String
  deviceToken String    @unique @default(uuid())
  label       String?
  lastSeenAt  DateTime?
  createdAt   DateTime  @default(now())

  station FactoryStation @relation(fields: [stationId], references: [id], onDelete: Cascade)
}

model FactoryCncMachineMap {
  id          String @id @default(cuid())
  machineName String @unique
  stationId   String

  station FactoryStation @relation(fields: [stationId], references: [id], onDelete: Cascade)
}

model FactoryCncDailySummary {
  id              String   @id @default(cuid())
  stationId       String
  summaryDate     DateTime @db.Date
  activeFraction  Decimal? @db.Decimal(6, 4)
  partsCount      Int      @default(0)
  intervalMinutes Int?
  pctFromBest     Decimal? @db.Decimal(6, 4)
  rawJson         Json?
  createdAt       DateTime @default(now())

  station FactoryStation @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@unique([stationId, summaryDate])
}

// ---- Factory planning (owner: factory) ----

/// Physical factory site (AKS / VAR / KAZ) with its planning spreadsheet.
model FactorySite {
  id            String   @id @default(cuid())
  code          String   @unique
  nameBg        String
  spreadsheetId String
  createdAt     DateTime @default(now())

  planningBatches FactoryPlanningBatch[]
  importRuns      FactoryPlanningImportRun[]
}

model FactoryBoothVersionCode {
  id                  String   @id @default(cuid())
  code                String   @unique
  description         String   @default("")
  productionFileLinks Json?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())

  planningBatches FactoryPlanningBatch[]
  planningBooths  FactoryPlanningBooth[]
}

model FactoryBatchProductionOption {
  id        String  @id @default(cuid())
  code      String  @unique
  labelBg   String
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  planningBatches FactoryPlanningBatch[]
}

model FactoryBoothProductionOption {
  id        String  @id @default(cuid())
  code      String  @unique
  labelBg   String
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  planningBooths FactoryPlanningBooth[]
}

model FactoryPlanningBatch {
  id                      String                     @id @default(cuid())
  siteId                  String
  batchCode               String                     @unique
  modelCode               String?
  status                  FactoryPlanningBatchStatus @default(proposed)
  priority                Int                        @default(1)
  plannedStart            DateTime?                  @db.Date
  plannedEnd              DateTime?                  @db.Date
  originalDeadline        DateTime?                  @db.Date
  isUsMarket              Boolean?
  boothVersionCodeId      String?
  batchProductionOptionId String?
  productionMonth         Int?
  productionYear          Int?
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt

  site                  FactorySite                   @relation(fields: [siteId], references: [id])
  model                 FactoryBoothModel?            @relation(fields: [modelCode], references: [code])
  boothVersionCode      FactoryBoothVersionCode?      @relation(fields: [boothVersionCodeId], references: [id])
  batchProductionOption FactoryBatchProductionOption? @relation(fields: [batchProductionOptionId], references: [id])
  booths                FactoryPlanningBooth[]

  @@index([siteId])
  @@index([productionYear, productionMonth])
}

model FactoryPlanningBooth {
  id                      String                      @id @default(cuid())
  planningBatchId         String
  boothUniqueId           String                      @unique
  modelCode               String?
  colorCode               String
  boothVersionCodeId      String?
  isUsMarket              Boolean                     @default(false)
  status                  FactoryPlanningBoothStatus?
  boothProductionOptionId String?
  sortOrder               Int                         @default(0)
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt

  planningBatch         FactoryPlanningBatch          @relation(fields: [planningBatchId], references: [id], onDelete: Cascade)
  model                 FactoryBoothModel?            @relation(fields: [modelCode], references: [code])
  boothVersionCode      FactoryBoothVersionCode?      @relation(fields: [boothVersionCodeId], references: [id])
  boothProductionOption FactoryBoothProductionOption? @relation(fields: [boothProductionOptionId], references: [id])

  @@index([planningBatchId])
}

model FactoryPlanningImportRun {
  id              String    @id @default(cuid())
  siteId          String
  productionMonth Int
  productionYear  Int
  /// 'import' | 'export' | 'factory_sync'
  direction       String
  rowsRead        Int?
  rowsUpserted    Int?
  rowsSkipped     Int?
  errors          Json?
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?

  site FactorySite @relation(fields: [siteId], references: [id])
}

// ---- RP spare parts / panels (owner: rp) ----

enum RpUrgency {
  standard
  urgent
}

enum RpSheetSyncStatus {
  pending
  processing
  synced
  failed
}

enum RpLineItemKind {
  panel
  part
}

enum RpLineItemFulfillment {
  pending
  from_stock
  shipped
}

enum RpStockReplacementSummary {
  none
  partial
  full
}

/// Rep.Parts26 header row.
model RpRequest {
  id                      String                    @id @default(cuid())
  rpNum                   String                    @unique @map("rp_num")
  entryDate               DateTime?                 @map("entry_date")
  market                  String?
  userId                  String?                   @map("user_id")
  issueType               String?                   @map("issue_type")
  urgency                 RpUrgency                 @default(standard)
  model                   String?
  boothId                 String?                   @map("booth_id")
  color                   String?
  itemType                String?                   @map("item_type")
  quantity                String?
  partRpCode              String?                   @map("part_rp_code")
  partDescription         String?                   @map("part_description")
  clarifications          String?
  notes                   String?
  client                  String?
  address                 String?
  recipient               String?
  phone                   String?
  email                   String?
  reviewGroup             String?                   @map("review_group")
  shipMethod              String?                   @map("ship_method")
  status                  String?
  tracking                String?
  readyMarkedAt           DateTime?                 @map("ready_marked_at")
  payer                   String?
  currentLocation         String?                   @map("current_location")
  workshopNote            String?                   @map("workshop_note")
  orderSentAt             DateTime?                 @map("order_sent_at")
  dueDate                 DateTime?                 @map("due_date")
  itemsJson               Json?                     @map("items_json")
  stockReplacementSummary RpStockReplacementSummary @default(none) @map("stock_replacement_summary")
  createdAt               DateTime                  @default(now()) @map("created_at")
  updatedAt               DateTime                  @updatedAt @map("updated_at")
  syncedAt                DateTime?                 @map("synced_at")

  lineItems               RpLineItem[]
  internalProductionRows  RpInternalProductionRow[] @relation("RpSourceRequest")
  photos                  RpPhoto[]

  @@index([status])
  @@index([reviewGroup])
  @@index([urgency])
  @@index([orderSentAt])
  @@map("rp_requests")
}

model RpLineItem {
  id                 String                @id @default(cuid())
  rpRequestId        String                @map("rp_request_id")
  lineIndex          Int                   @map("line_index")
  kind               RpLineItemKind
  panelName          String?               @map("panel_name")
  quantity           String?
  partRpCode         String?               @map("part_rp_code")
  partDescription    String?               @map("part_description")
  clarifications     String?
  fulfillment        RpLineItemFulfillment @default(pending)
  takenFromStockAt   DateTime?             @map("taken_from_stock_at")
  takenFromStockBy   String?               @map("taken_from_stock_by")
  stockReplacementIpId String?             @unique @map("stock_replacement_ip_id")
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")

  rpRequest          RpRequest             @relation(fields: [rpRequestId], references: [id], onDelete: Cascade)
  stockReplacementIp RpInternalProductionRow? @relation("LineItemStockIp", fields: [stockReplacementIpId], references: [id], onDelete: SetNull)
  sourceIpRows       RpInternalProductionRow[] @relation("LineItemSource")

  @@unique([rpRequestId, lineIndex])
  @@index([rpRequestId])
  @@index([fulfillment])
  @@map("rp_line_items")
}

/// Internal Production sheet row.
model RpInternalProductionRow {
  id                   String     @id @default(cuid())
  ipNum                String     @unique @map("ip_num")
  entryDate            DateTime?  @map("entry_date")
  deadline             DateTime?
  ownerEmail           String?    @map("owner_email")
  reason               String?
  urgency              RpUrgency  @default(standard)
  model                String?
  batch                String?
  colour               String?
  panel                String?
  panelClarification   String?    @map("panel_clarification")
  notes                String?
  warehouse            String?
  factory              String?
  status               String?
  tracking             String?
  payer                String?
  sourceRpId           String?    @map("source_rp_id")
  sourceLineItemId     String?    @unique @map("source_line_item_id")
  sourceRpNum          String?    @map("source_rp_num")
  workshopNote         String?    @map("workshop_note")
  orderSentAt          DateTime?  @map("order_sent_at")
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")
  syncedAt             DateTime?  @map("synced_at")

  sourceRp             RpRequest?  @relation("RpSourceRequest", fields: [sourceRpId], references: [id], onDelete: SetNull)
  sourceLineItem       RpLineItem? @relation("LineItemSource", fields: [sourceLineItemId], references: [id], onDelete: SetNull)
  stockForLineItem     RpLineItem? @relation("LineItemStockIp")

  @@index([sourceRpNum])
  @@index([sourceRpId])
  @@index([factory])
  @@map("internal_production_rows")
}

model RpPhoto {
  id          String   @id @default(cuid())
  rpRequestId String   @map("rp_request_id")
  storageKey  String   @map("storage_key")
  url         String
  label       String?
  mimeType    String?  @map("mime_type")
  byteSize    Int?     @map("byte_size")
  createdAt   DateTime @default(now()) @map("created_at")

  rpRequest RpRequest @relation(fields: [rpRequestId], references: [id], onDelete: Cascade)

  @@index([rpRequestId])
  @@map("rp_photos")
}

model RpAutomationState {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("automation_state")
}

model RpSheetRowMap {
  id         String   @id @default(cuid())
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  sheetName  String   @map("sheet_name")
  rowNumber  Int      @map("row_number")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([entityType, entityId, sheetName])
  @@map("sheet_row_map")
}

model RpSheetSyncOutbox {
  id          String            @id @default(cuid())
  entityType  String            @map("entity_type")
  entityId    String            @map("entity_id")
  operation   String
  payloadJson Json?             @map("payload_json")
  status      RpSheetSyncStatus @default(pending)
  attempts    Int               @default(0)
  lastError   String?           @map("last_error")
  createdAt   DateTime          @default(now()) @map("created_at")
  processedAt DateTime?         @map("processed_at")

  @@index([status])
  @@map("sheet_sync_outbox")
}

model RpAddressBookEntry {
  id        String   @id @default(cuid())
  client    String
  address   String?
  recipient String?
  phone     String?
  email     String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([client])
  @@map("address_book_entries")
}

model RpPanelCatalogOption {
  id        String @id @default(cuid())
  category  String?
  value     String
  sortOrder Int    @default(0) @map("sort_order")

  @@map("panel_catalog_options")
}

model RpExportTrackingRow {
  id           String   @id @default(cuid())
  rpNum        String   @unique @map("rp_num")
  trackingText String?  @map("tracking_text")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("export_tracking_rows")
}

model RpNumSequence {
  id        String @id
  lastValue Int    @default(0) @map("last_value")

  @@map("rp_num_sequences")
}

model RpIpNumSequence {
  id        String @id
  lastValue Int    @default(0) @map("last_value")

  @@map("ip_num_sequences")
}

// ---- Clock-In (owner: clock app, clock.meavo.app) ----

enum ClockPendingStatus {
  PENDING
  ASSIGNED
  EXPIRED
}

enum ClockEventType {
  IN
  OUT
}

model ClockWorker {
  id        String   @id @default(cuid())
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  cardBindings ClockCardBinding[]
  clockEvents  ClockEvent[]

  @@map("clock_workers")
}

model ClockCardBinding {
  id            String    @id @default(cuid())
  uid           String
  workerId      String    @map("worker_id")
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now()) @map("created_at")
  deactivatedAt DateTime? @map("deactivated_at")

  worker ClockWorker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([uid, active])
  @@map("clock_card_bindings")
}

model ClockPendingUid {
  id        String             @id @default(cuid())
  uid       String
  stationId String             @map("station_id")
  tappedAt  String             @map("tapped_at")
  expiresAt DateTime           @map("expires_at")
  status    ClockPendingStatus @default(PENDING)
  createdAt DateTime           @default(now()) @map("created_at")

  unassignedTaps ClockUnassignedTap[]

  @@index([status])
  @@index([uid])
  @@map("clock_pending_uids")
}

model ClockUnassignedTap {
  id           String   @id @default(cuid())
  uid          String
  stationId    String   @map("station_id")
  tappedAt     String   @map("tapped_at")
  pendingUidId String?  @map("pending_uid_id")
  createdAt    DateTime @default(now()) @map("created_at")

  pendingUid ClockPendingUid? @relation(fields: [pendingUidId], references: [id])

  @@map("clock_unassigned_taps")
}

model ClockEvent {
  id             String         @id @default(cuid())
  uid            String
  workerId       String         @map("worker_id")
  stationId      String         @map("station_id")
  eventType      ClockEventType @map("event_type")
  tappedAt       String         @map("tapped_at")
  idempotencyKey String         @unique @map("idempotency_key")
  createdAt      DateTime       @default(now()) @map("created_at")

  worker ClockWorker @relation(fields: [workerId], references: [id])

  @@index([tappedAt])
  @@index([workerId])
  @@map("clock_events")
}

model ClockWorkSettings {
  id         String @id @default("default")
  shiftStart String @default("07:30") @map("shift_start")
  shiftEnd   String @default("16:30") @map("shift_end")
  timezone   String @default("Europe/Sofia")

  @@map("clock_work_settings")
}

// ---- Task management (owner: tasks) ----

enum TaskWorkspaceType {
  PERSONAL
  TEAM
  SHARED
}

enum TaskWorkspaceRole {
  VIEWER
  EDITOR
}

enum TaskPriority {
  NONE
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  OPEN
  COMPLETED
  CANCELLED
}

enum TaskLinkedApp {
  SALES
  FACTORY
  RP
  ASSEMBLY
  MRP
}

enum TaskAssigneeScope {
  MEMBER
  EXTERNAL
}

model TaskWorkspace {
  id         String            @id @default(cuid())
  type       TaskWorkspaceType
  name       String
  ownerId    String
  teamId     String?
  color      String            @default("#EEDCDC")
  archivedAt DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  owner   User                  @relation("TaskWorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  team    Team?                 @relation(fields: [teamId], references: [id], onDelete: SetNull)
  members TaskWorkspaceMember[]
  columns TaskBoardColumn[]
  tasks   Task[]

  @@index([ownerId])
  @@index([teamId])
  @@index([type])
}

model TaskWorkspaceMember {
  id          String            @id @default(cuid())
  workspaceId String
  userId      String
  role        TaskWorkspaceRole @default(VIEWER)
  createdAt   DateTime          @default(now())

  workspace TaskWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model TaskBoardColumn {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace TaskWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@index([workspaceId, position])
}

model Task {
  id          String       @id @default(cuid())
  workspaceId String
  columnId    String?
  position    Int          @default(0)
  title       String
  description String       @default("")
  priority    TaskPriority @default(NONE)
  status      TaskStatus   @default(OPEN)
  startDate   DateTime?    @db.Date
  dueDate     DateTime?    @db.Date
  createdById String
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  workspace   TaskWorkspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  column      TaskBoardColumn?   @relation(fields: [columnId], references: [id], onDelete: SetNull)
  createdBy   User               @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Restrict)
  assignees   TaskAssignee[]
  externalLinks TaskExternalLink[]

  @@index([workspaceId, columnId, position])
  @@index([dueDate])
  @@index([workspaceId, status])
  @@index([createdById])
}

model TaskAssignee {
  id        String            @id @default(cuid())
  taskId    String
  userId    String
  scope     TaskAssigneeScope @default(MEMBER)
  createdAt DateTime          @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
  @@index([userId, scope])
}

model TaskExternalLink {
  id           String        @id @default(cuid())
  taskId       String
  linkedApp    TaskLinkedApp
  entityType   String
  entityId     String
  displayLabel String        @default("")
  deepLinkUrl  String        @default("")
  createdAt    DateTime      @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([linkedApp, entityType, entityId])
}
